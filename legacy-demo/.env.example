# Copy this file to .env and fill in your real values. Never commit .env.

# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use for the AI Emergency Brief + chat assistant.
# gemini-2.5-flash is a good default (fast + cheap). gemini-2.5-pro for higher quality.
GEMINI_MODEL=gemini-2.5-flash

# Port the local server runs on
PORT=3000
